---
import type { Job } from '../lib/supabase';
import { Calendar, ExternalLink, MapPin, IndianRupee } from 'lucide-react';

interface Props {
  job: Job;
}

const { job } = Astro.props;

// Determine if closing soon (<= 5 days)
const now = new Date();
const closing = new Date(job.closing_date);
const diffTime = closing.getTime() - now.getTime();
const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
const isClosingSoon = diffDays >= 0 && diffDays <= 5;

// Format closing date
const formatClosingDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
};
---

<article 
  class="job-card-wrapper bg-white border-brutal rounded-[14px] shadow-brutal flex flex-col relative transition-all hover:-translate-y-1 hover:shadow-brutal-hover"
  data-category={job.category}
  data-location={job.location}
  data-ctc={job.ctc_max}
  data-bond={job.bond_period}
  data-posted-date={job.posted_date}
  data-closing-date={job.closing_date}
  data-title={job.title}
  data-company={job.company_name}
>
  <!-- Optional: Sample Tag Badge -->
  {job.is_sample && (
    <span class="absolute -top-3 -right-2 bg-coral text-white font-mono text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 border-2 border-ink rounded-md rotate-3 shadow-[2px_2px_0px_0px_var(--ink)] z-20">
      Sample listing
    </span>
  )}

  <!-- TOP SECTION -->
  <div class="p-6 flex-1 flex flex-col justify-between">
    <div>
      <!-- Req # & Batch -->
      <div class="flex items-center justify-between gap-2 mb-3">
        <span class="font-mono text-xs font-bold text-slate uppercase">
          {job.batch_year} &middot; {job.req_number || 'N/A'}
        </span>
        
        <!-- Status dot -->
        <span class="flex items-center gap-1.5 bg-cream border-2 border-ink px-2.5 py-0.5 rounded-full text-[10px] font-mono font-bold text-ink">
          <span class={`w-2.5 h-2.5 rounded-full border border-ink ${isClosingSoon ? 'bg-amber animate-pulse' : 'bg-coral'}`}></span>
          {isClosingSoon ? 'CLOSING SOON' : 'OPEN'}
        </span>
      </div>

      <!-- Job Title -->
      <h3 class="font-display text-xl sm:text-2xl font-black text-ink mb-1.5 group-hover:text-coral leading-tight">
        {job.title}
      </h3>

      <!-- Company Name -->
      <div class="flex items-center gap-2 mb-4">
        {job.company_logo_url && (
          <img 
            src={job.company_logo_url} 
            alt={`${job.company_name} Logo`} 
            class="w-5 h-5 rounded-full border border-ink object-cover" 
            loading="lazy"
          />
        )}
        <span class="font-sans text-sm font-bold text-ink">{job.company_name}</span>
      </div>
    </div>

    <!-- Tags (Location / CTC) -->
    <div class="flex flex-wrap gap-2.5">
      <span class="inline-flex items-center gap-1 bg-lime text-ink font-sans text-xs font-bold border-2 border-ink px-2.5 py-1 rounded-full shadow-[1px_1px_0px_0px_var(--ink)]">
        <MapPin class="w-3.5 h-3.5" />
        {job.location}
      </span>
      <span class="inline-flex items-center gap-1 bg-lime text-ink font-sans text-xs font-bold border-2 border-ink px-2.5 py-1 rounded-full shadow-[1px_1px_0px_0px_var(--ink)]">
        <IndianRupee class="w-3.5 h-3.5" />
        {job.ctc_min === job.ctc_max ? `${job.ctc_min} LPA` : `${job.ctc_min} - ${job.ctc_max} LPA`}
      </span>
      <span class="inline-flex items-center gap-1 bg-cream text-ink font-sans text-xs font-bold border-2 border-ink px-2.5 py-1 rounded-full shadow-[1px_1px_0px_0px_var(--ink)]">
        Bond: {job.bond_period}
      </span>
    </div>
  </div>

  <!-- TICKET STUB PERFORATION DIVIDER -->
  <div class="relative py-1 w-full overflow-visible">
    <!-- Left Cutout Circle -->
    <div class="absolute -left-[13px] top-1/2 -translate-y-1/2 w-6 h-6 bg-cream border-2 border-ink rounded-full z-10"></div>
    <!-- Right Cutout Circle -->
    <div class="absolute -right-[13px] top-1/2 -translate-y-1/2 w-6 h-6 bg-cream border-2 border-ink rounded-full z-10"></div>
    <!-- Dashed Line -->
    <div class="border-t-2 border-dashed border-ink/40 w-full"></div>
  </div>

  <!-- BOTTOM SECTION -->
  <div class="p-6 pt-4 flex items-center justify-between bg-cream/20 rounded-b-[14px]">
    <div class="flex items-center gap-1.5 font-mono text-xs font-semibold">
      <Calendar class="w-3.5 h-3.5 text-slate" />
      <span class="text-slate">Closes:</span>
      <span class={isClosingSoon ? 'text-coral font-bold' : 'text-ink font-bold'}>
        {formatClosingDate(job.closing_date)}
      </span>
    </div>

    <a 
      href={job.apply_url} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="btn-brutal bg-ink text-cream hover:text-white font-sans font-bold px-4 py-2 rounded-full text-xs flex items-center gap-1 cursor-pointer"
      aria-label={`Apply to ${job.title} at ${job.company_name} (external link)`}
    >
      Apply <ExternalLink class="w-3 h-3" />
    </a>
  </div>
</article>
