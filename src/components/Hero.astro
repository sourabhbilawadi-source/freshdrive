---
---
<section class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 my-8">
  <!-- Outer Lime Card -->
  <div class="bg-lime border-brutal-3 rounded-3xl p-6 shadow-brutal">
    <!-- Inner Cream Card -->
    <div class="bg-cream border-brutal p-8 sm:p-12 rounded-2xl flex flex-col lg:flex-row items-center justify-between gap-12 relative overflow-hidden">
      
      <!-- Text content (Left side) -->
      <div class="flex-1 z-10 flex flex-col items-start text-left max-w-xl">
        <span class="inline-block bg-white text-ink border-brutal text-xs font-mono font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-6">
          FRESHER JOB TRACKER · PAN INDIA
        </span>
        
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-black text-ink leading-tight mb-6">
          From campus to career, <span class="text-coral underline decoration-wavy decoration-ink decoration-3 underline-offset-8">tracked daily.</span>
        </h1>
        
        <p class="font-sans text-lg font-semibold text-slate mb-8 max-w-lg">
          FreshDrive aggregates verified entry-level job openings directly from company career pages. No middleman, no fake listings.
        </p>
        
        <div class="flex flex-wrap gap-4 w-full sm:w-auto">
          <a 
            href="#listings" 
            class="btn-brutal bg-coral text-ink font-sans font-bold px-8 py-3.5 rounded-full text-center hover:bg-coral/95 active:bg-coral cursor-pointer flex-1 sm:flex-initial"
          >
            Browse roles
          </a>
          <a 
            href="#how-it-works" 
            class="btn-brutal bg-white text-ink font-sans font-bold px-8 py-3.5 rounded-full text-center hover:bg-cream/40 cursor-pointer flex-1 sm:flex-initial"
          >
            How it works
          </a>
        </div>
      </div>

      <!-- Custom SVG Illustration (Right side, hidden on mobile/tablet) -->
      <div class="hidden lg:block w-full max-w-[420px] aspect-[420/300] relative">
        <svg viewBox="0 0 420 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" aria-hidden="true">
          <!-- Background grids or decor -->
          <circle cx="210" cy="150" r="140" fill="var(--lime)" fill-opacity="0.15" />
          <path d="M10 280 H410" stroke="var(--ink)" stroke-width="3" stroke-linecap="round" />
          
          <!-- Small "Campus" Building (Left) -->
          <!-- Building Base -->
          <rect x="30" y="200" width="90" height="80" rx="4" fill="var(--lime)" stroke="var(--ink)" stroke-width="3" />
          <!-- Pitch Roof -->
          <path d="M25 200 L75 160 L125 200 Z" fill="var(--coral)" stroke="var(--ink)" stroke-width="3" stroke-linejoin="round" />
          <!-- Building Details: Door -->
          <rect x="65" y="240" width="20" height="40" rx="2" fill="var(--cream)" stroke="var(--ink)" stroke-width="3" />
          <!-- Windows -->
          <rect x="45" y="215" width="16" height="16" rx="2" fill="var(--cream)" stroke="var(--ink)" stroke-width="2.5" />
          <rect x="89" y="215" width="16" height="16" rx="2" fill="var(--cream)" stroke="var(--ink)" stroke-width="2.5" />
          <!-- Flag pole -->
          <line x1="75" y1="160" x2="75" y2="135" stroke="var(--ink)" stroke-width="3" />
          <path d="M75 135 L95 142.5 L75 150 Z" fill="var(--cream)" stroke="var(--ink)" stroke-width="2.5" stroke-linejoin="round" />
          <text x="75" y="278" font-family="Fraunces" font-weight="900" font-size="10" fill="var(--ink)" text-anchor="middle">COLLEGE</text>

          <!-- Taller "Office" Building (Right) -->
          <!-- Main Tower -->
          <rect x="290" y="60" width="100" height="220" rx="6" fill="var(--cream)" stroke="var(--ink)" stroke-width="3" />
          <!-- Accent top roof -->
          <rect x="310" y="45" width="60" height="15" rx="2" fill="var(--coral)" stroke="var(--ink)" stroke-width="3" />
          <!-- Windows grid -->
          <rect x="310" y="80" width="20" height="20" rx="3" fill="var(--lime)" stroke="var(--ink)" stroke-width="2.5" />
          <rect x="350" y="80" width="20" height="20" rx="3" fill="var(--lime)" stroke="var(--ink)" stroke-width="2.5" />
          <rect x="310" y="115" width="20" height="20" rx="3" fill="var(--lime)" stroke="var(--ink)" stroke-width="2.5" />
          <rect x="350" y="115" width="20" height="20" rx="3" fill="var(--lime)" stroke="var(--ink)" stroke-width="2.5" />
          <rect x="310" y="150" width="20" height="20" rx="3" fill="var(--lime)" stroke="var(--ink)" stroke-width="2.5" />
          <rect x="350" y="150" width="20" height="20" rx="3" fill="var(--lime)" stroke="var(--ink)" stroke-width="2.5" />
          <rect x="310" y="185" width="20" height="20" rx="3" fill="var(--lime)" stroke="var(--ink)" stroke-width="2.5" />
          <rect x="350" y="185" width="20" height="20" rx="3" fill="var(--lime)" stroke="var(--ink)" stroke-width="2.5" />
          <!-- Ground entry door -->
          <rect x="325" y="235" width="30" height="45" rx="3" fill="var(--ink)" stroke="var(--ink)" stroke-width="3" />
          <text x="340" y="222" font-family="Fraunces" font-weight="900" font-size="12" fill="var(--ink)" text-anchor="middle">CAREER</text>

          <!-- Ladder connecting Campus roof (75, 160) to Office Window (290, 115) -->
          <g>
            <!-- Left rail -->
            <line x1="120" y1="180" x2="295" y2="100" stroke="var(--ink)" stroke-width="4.5" stroke-linecap="round" />
            <!-- Right rail -->
            <line x1="126" y1="192" x2="301" y2="112" stroke="var(--ink)" stroke-width="4.5" stroke-linecap="round" />
            
            <!-- Rungs -->
            <line x1="145" y1="172" x2="151" y2="182" stroke="var(--ink)" stroke-width="3" />
            <line x1="170" y1="160" x2="176" y2="170" stroke="var(--ink)" stroke-width="3" />
            <line x1="195" y1="148" x2="201" y2="158" stroke="var(--ink)" stroke-width="3" />
            <line x1="220" y1="137" x2="226" y2="147" stroke="var(--ink)" stroke-width="3" />
            <line x1="245" y1="125" x2="251" y2="135" stroke="var(--ink)" stroke-width="3" />
            <line x1="270" y1="113" x2="276" y2="123" stroke="var(--ink)" stroke-width="3" />
          </g>

          <!-- Graduate Figure Climbing (Diagonally positioned on the ladder) -->
          <g transform="translate(200, 110) rotate(-22)">
            <!-- Gown Body (Triangle) -->
            <path d="M 0 0 L -12 28 L 12 28 Z" fill="var(--coral)" stroke="var(--ink)" stroke-width="2.5" stroke-linejoin="round" />
            <!-- Limbs (climbing positions) -->
            <!-- Left leg -->
            <path d="M -6 28 L -9 38 L -5 39" stroke="var(--ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            <!-- Right leg -->
            <path d="M 6 28 L 9 34 L 13 33" stroke="var(--ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            <!-- Left arm -->
            <path d="M -8 10 L -14 5 L -10 0" stroke="var(--ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            <!-- Right arm -->
            <path d="M 8 10 L 14 8 L 11 2" stroke="var(--ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            <!-- Neck & Head -->
            <circle cx="0" cy="-6" r="6" fill="var(--cream)" stroke="var(--ink)" stroke-width="2.5" />
            <!-- Mortarboard Cap -->
            <path d="M -12 -12 L 0 -18 L 12 -12 L 0 -6 Z" fill="var(--ink)" stroke="var(--ink)" stroke-width="1.5" stroke-linejoin="round" />
            <rect x="-2" y="-12" width="4" height="6" fill="var(--ink)" />
            <!-- Tassel -->
            <path d="M 0 -12 L 8 -9 L 8 -5" stroke="var(--lime)" stroke-width="1.5" stroke-linecap="round" />
          </g>
        </svg>
      </div>

    </div>
  </div>
</section>
